# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Anthropic (Claude AI) ───
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Google Auth (configured in Supabase dashboard) ───
# No env vars needed — Google OAuth is set up in Supabase Auth settings

# --- Admin panel (server-side protected) ---
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
ADMIN_EMAILS=admin1@example.com,admin2@example.com

# --- Google Maps ---
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-browser-key

# --- Sentry (optional, recommended) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_APP_ENV=development

